# Copy to .env and fill in values. Never commit .env to git.

# LLM claim extraction (optional — auto mode uses if present)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Materials Project connector (optional)
MATERIALS_PROJECT_API_KEY=

# REST API shared secret (optional — when set, requires X-API-Key header)
# VSA_API_KEY=

# API rate limiting (optional — requests per 60s per client IP)
# VSA_API_RATE_LIMIT=120

# Force rule-based build/audit on API (optional)
# VSA_API_DETERMINISTIC=1

# OpenTelemetry (optional — requires [otel] extra)
# VSA_OTEL_ENABLED=1

# TLS: set to false only if your environment has certificate issues (not recommended)
# VSA_SSL_VERIFY=true
